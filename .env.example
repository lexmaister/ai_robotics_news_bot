# =============================================================================
# AI & Robotics News Curation Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# .env is gitignored and never committed.
# All other configuration (intervals, model names, queries) lives in
# config/settings.yml and config/sources_whitelist.yml.
# =============================================================================


# --- PostgreSQL ---------------------------------------------------------------
# Password for the `prefect` database user created on first container start.
# Must match across all services that connect to PostgreSQL.
# Choose a strong random password (e.g. openssl rand -hex 32).
POSTGRES_PASSWORD=<PASSWORD>


# --- NewsData.io --------------------------------------------------------------
# API key frxdom https://newsdata.io/api-key (free tier: 200 credits/day)
NEWSDATA_API_KEY=<KEY>


# --- OpenRouter ---------------------------------------------------------------
# API key from https://openrouter.ai/keys
# Used for categorization (task 4), curation (task 5), and embedding (task 7).
OPENROUTER_API_KEY=<KEY>


# --- Telegram Bot -------------------------------------------------------------
# Bot token from @BotFather on Telegram (https://t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=<TOKEN>

# Target channel: numeric ID (e.g. -1001234567890) or public username (@mychannel)
# The bot must be an admin of this channel with "Post Messages" permission.
TELEGRAM_CHANNEL_ID=@your_channel_username


# --- Proxy (optional) ---------------------------------------------------------
# HTTP/SOCKS5 proxy for outbound Telegram API calls.
# Leave blank (or omit) if no proxy is needed.
# Examples:
#   http://user:pass@proxy.example.com:8080
#   socks5://user:pass@proxy.example.com:1080
TELEGRAM_PROXY_URL=
